---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>

<!-- ═══════════════════════════════════════
     NAV
═══════════════════════════════════════ -->
<header class="fixed top-0 left-0 right-0 z-50 nav-glass" id="nav">
  <div class="container-main py-4">
    <div class="flex items-center justify-between">

      <a href="/" class="heading-md transition-opacity hover:opacity-80">
        <span class="gradient-text">Quentin "Q" Maestripieri</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#services">Services</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#work">Experience</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#about">About</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#contact">Contact</a>
        <a class="btn-secondary text-sm py-2.5 px-5" href="https://calendly.com/quentin-maestripieri/30min">
          Book a Call
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="md:hidden relative w-6 h-6"
        style="color: var(--color-text-secondary);"
        id="menu-toggle"
        aria-label="Toggle menu"
      >
        <span class="block absolute left-0 w-6 h-0.5 bg-current transition-all duration-300" id="line1" style="top:4px"></span>
        <span class="block absolute left-0 w-6 h-0.5 bg-current transition-all duration-300" id="line2" style="top:11px"></span>
        <span class="block absolute left-0 w-6 h-0.5 bg-current transition-all duration-300" id="line3" style="top:18px"></span>
      </button>
    </div>

    <!-- Mobile nav -->
    <nav class="md:hidden overflow-hidden transition-all duration-300 ease-in-out" id="mobile-menu" style="max-height:0">
      <div class="flex flex-col gap-4 pt-6 pb-2 border-t mt-4" style="border-color:var(--color-border)">
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#services" onclick="closeMobileMenu()">Services</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#work"     onclick="closeMobileMenu()">Experience</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#about"    onclick="closeMobileMenu()">About</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#contact"  onclick="closeMobileMenu()">Contact</a>
        <a class="btn-secondary text-sm py-2.5 px-5 justify-center mt-2" href="https://calendly.com/quentin-maestripieri/30min">
          Book a Call
        </a>
      </div>
    </nav>
  </div>
</header>

<div class="h-16"></div>

<main>

<!-- ═══════════════════════════════════════
     TEAMS AND PROJECTS SUPPORTED
═══════════════════════════════════════ -->
<section id="work" class="section-padding bg-primary relative">
  <div class="absolute top-0 left-0 right-0 divider"></div>

  <div class="container-main">
    <div class="grid md:grid-cols-2 gap-8 mb-16">
      <div>
        <span class="label block mb-4">Experience</span>
        <h2 class="heading-lg">
          Some teams I've supported throughout my career.
        </h2>
      </div>
      <div class="flex items-end">
        <p class="text-body">
          Every role below involved direct accountability for outcomes, people, and multi-million-franc budgets — in environments where failure wasn't an option.
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

      <!-- Role 16 -->
      <div class="card p-8 relative overflow-hidden group">
        <div class="number-badge">16</div>
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="heading-md">Financial Infrastructure</h3>
            <span class="years-badge">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              6 months
            </span>
          </div>
          <p class="text-body-sm mb-4 text-muted">2026</p>
          <h4 class="text-body mb-4" style="color:var(--color-text-primary)">Team and Product Stabilization</h4>
          <p class="text-body-sm mb-6">
            Led a DevOps Engineering Team (12 FTE in CH and SP) in charge of a high-availability, mission critical platform for secured data transfers.
          </p>
          <div class="flex flex-wrap gap-2">
            {["Network & Connectivity", "Secure Transfers", "L2/L3/L4", "CH and SP"].map(t => (
              <span class="text-xs px-3 py-1 rounded-full border text-muted" style="border-color:var(--color-border)">{t}</span>
            ))}
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(127,127,125,0.05)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>

      <!-- Role 15 -->
      <div class="card p-8 relative overflow-hidden group">
        <div class="number-badge">15</div>
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="heading-md">eCommerce</h3>
            <span class="years-badge">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              2 months
            </span>
          </div>
          <p class="text-body-sm mb-4 text-muted">2025</p>
          <h4 class="text-body mb-4" style="color:var(--color-text-primary)">Strategy Initiation</h4>
          <p class="text-body-sm mb-6">
            Defined implementation roadmap of the digital growth initiative for a Non-Life insurer, including alignement with market best practices, BC-sizing and priorization of a 3 years implementation journey.
          </p>
          <div class="flex flex-wrap gap-2">
            {["Digital Sales", "eMarketing", "Insurance", "CH"].map(t => (
              <span class="text-xs px-3 py-1 rounded-full border text-muted" style="border-color:var(--color-border)">{t}</span>
            ))}
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(127,127,125,0.05)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>
      
      <!-- Role 14 -->
      <div class="card p-8 relative overflow-hidden group">
        <div class="number-badge">14/div>
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="heading-md">eCommerce</h3>
            <span class="years-badge">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              2 months
            </span>
          </div>
          <p class="text-body-sm mb-4 text-muted">2025</p>
          <h4 class="text-body mb-4" style="color:var(--color-text-primary)">Strategy Initiation</h4>
          <p class="text-body-sm mb-6">
            Defined implementation roadmap of the digital growth initiative for a Non-Life insurer, including alignement with market best practices, BC-sizing and priorization of a 3 years implementation journey.
          </p>
          <div class="flex flex-wrap gap-2">
            {["Digital Sales", "eMarketing", "Insurance", "CH"].map(t => (
              <span class="text-xs px-3 py-1 rounded-full border text-muted" style="border-color:var(--color-border)">{t}</span>
            ))}
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(127,127,125,0.05)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>
      
      <!-- Role placeholder -->
      <div class="card p-8 relative overflow-hidden group">
        <div class="number-badge">00</div>
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="heading-md">Industry</h3>
            <span class="years-badge">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              duration
            </span>
          </div>
          <p class="text-body-sm mb-4 text-muted">YEAR</p>
          <h4 class="text-body mb-4" style="color:var(--color-text-primary)">Summary</h4>
          <p class="text-body-sm mb-6">
            Description
          </p>
          <div class="flex flex-wrap gap-2">
            {["Tag", "Tag", "Tag", "Tag"].map(t => (
              <span class="text-xs px-3 py-1 rounded-full border text-muted" style="border-color:var(--color-border)">{t}</span>
            ))}
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(127,127,125,0.05)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>

</main>

<!-- ═══════════════════════════════════════
     FOOTER
═══════════════════════════════════════ -->
<footer class="py-8 bg-secondary" style="border-top:1px solid var(--color-border)">
  <div class="container-main flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-body-sm text-muted">© 2026 Quentin Maestripieri. All rights reserved.</p>
    <p class="text-sm" style="color: var(--color-text-muted);">
      Built with <span class="text-accent">AI + own brain</span>
    </p>
  </div>
</footer>

</Layout>

<script>
  // ── Mobile menu toggle ─────────────────────
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const line1  = document.getElementById('line1');
  const line2  = document.getElementById('line2');
  const line3  = document.getElementById('line3');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    if (menu) menu.style.maxHeight = open ? menu.scrollHeight + 'px' : '0';
    if (line1) line1.style.transform = open ? 'rotate(45deg) translate(5px,5px)' : '';
    if (line2) line2.style.opacity   = open ? '0' : '1';
    if (line3) line3.style.transform = open ? 'rotate(-45deg) translate(5px,-5px)' : '';
  });

  (window as any).closeMobileMenu = () => {
    open = false;
    if (menu) menu.style.maxHeight = '0';
    if (line1) line1.style.transform = '';
    if (line2) line2.style.opacity = '1';
    if (line3) line3.style.transform = '';
  };
</script>
