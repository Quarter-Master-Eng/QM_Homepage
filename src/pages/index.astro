---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>

<!-- ═══════════════════════════════════════
     NAV
═══════════════════════════════════════ -->
<header class="fixed top-0 left-0 right-0 z-50 nav-glass" id="nav">
  <div class="container-main py-4">
    <div class="flex items-center justify-between">

      <a href="/" class="heading-md transition-opacity hover:opacity-80">
        <span class="gradient-text">Quentin "Q" Maestripieri</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#services">Services</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#work">Experience</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#about">About</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#contact">Contact</a>
        <a class="btn-secondary text-sm py-2.5 px-5" href="https://calendly.com/quentin-maestripieri/30min">
          Book a Call
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="md:hidden relative w-6 h-6"
        style="color: var(--color-text-secondary);"
        id="menu-toggle"
        aria-label="Toggle menu"
      >
        <span class="block absolute left-0 w-6 h-0.5 bg-current transition-all duration-300" id="line1" style="top:4px"></span>
        <span class="block absolute left-0 w-6 h-0.5 bg-current transition-all duration-300" id="line2" style="top:11px"></span>
        <span class="block absolute left-0 w-6 h-0.5 bg-current transition-all duration-300" id="line3" style="top:18px"></span>
      </button>
    </div>

    <!-- Mobile nav -->
    <nav class="md:hidden overflow-hidden transition-all duration-300 ease-in-out" id="mobile-menu" style="max-height:0">
      <div class="flex flex-col gap-4 pt-6 pb-2 border-t mt-4" style="border-color:var(--color-border)">
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#services" onclick="closeMobileMenu()">Services</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#work"     onclick="closeMobileMenu()">Experience</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#about"    onclick="closeMobileMenu()">About</a>
        <a class="link-hover text-sm" href="https://quentinmaestripieri.com/#contact"  onclick="closeMobileMenu()">Contact</a>
        <a class="btn-secondary text-sm py-2.5 px-5 justify-center mt-2" href="https://calendly.com/quentin-maestripieri/30min">
          Book a Call
        </a>
      </div>
    </nav>
  </div>
</header>

<div class="h-16"></div>

<main>

<!-- ═══════════════════════════════════════
     HERO
═══════════════════════════════════════ -->
<section class="min-h-screen bg-primary flex items-center relative overflow-hidden">
  <!-- Ambient glows -->
  <div class="absolute top-1/4 -right-1/4 w-[800px] h-[800px] pointer-events-none"
       style="background:radial-gradient(circle,rgba(127,127,125,0.07) 0%,transparent 70%)"></div>
  <div class="absolute -bottom-1/4 -left-1/4 w-[600px] h-[600px] pointer-events-none"
       style="background:radial-gradient(circle,rgba(127,127,125,0.04) 0%,transparent 70%)"></div>

  <div class="container-main py-20">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12 lg:gap-16">

      <!-- Text block -->
      <div class="max-w-2xl">
        <div class="animate-fade-in-up delay-100 mb-8">
          <span class="label">Crisis Consultant · Interim Manager · Switzerland / EU</span>
        </div>

        <h1 class="heading-xl animate-fade-in-up delay-200 mb-8">
          <span class="gradient-text">I reboot your teams<br/>out of crisis</span>
        </h1>

        <p class="text-body-sm text-primary max-w-xl mb-12">
          Mission-critical interventions with 24/7 engagement.
          I take full control, stabilise failing human architectures,
          and hand back a team that works.
        </p>

        <!-- Stats row -->
        <div class="flex justify-between sm:justify-start sm:gap-12 mb-12 animate-fade-in-up delay-500">
          <div>
            <p class="heading-md text-primary">20 years</p>
            <p class="text-body text-muted hidden sm:block">in senior (corporate) leadership</p>
            <p class="text-body text-muted sm:hidden">in senior<br/>(corporate) leadership</p>
          </div>
          <div>
            <p class="heading-md text-primary">15+ teams</p>
            <p class="text-body text-muted hidden sm:block">and projects led to safety</p>
            <p class="text-body text-muted sm:hidden">and major led<br/>to safety</p>
          </div>
          <div>
            <p class="heading-md text-primary">+/- 6 months</p>
            <p class="text-body text-muted hidden sm:block">typical mandate length</p>
            <p class="text-body text-muted sm:hidden">typical mandate<br/>length</p>
          </div>
        </div>
        
        <!-- CTA -->
        <div class="flex flex-wrap gap-4 animate-fade-in-up delay-600">
          <a href="https://calendly.com/quentin-maestripieri/30min" class="btn-primary">
            Book a Discovery Call
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
        
        <!-- Mobile photo -->
        <div class="lg:hidden mt-12 animate-fade-in delay-700">
          <img src="/pro_web_bnw.jpg" alt="Quentin Maestripieri" class="w-full sm:w-48 rounded-xl grayscale opacity-90" />
        </div>
        
      </div>

      <!-- Desktop photo -->
      <div class="hidden lg:block flex-shrink-0 animate-fade-in delay-500">
        <div class="relative">
          <img src="/pro_web_bnw.jpg" alt="Quentin Maestripieri"
               class="w-[280px] xl:w-[320px] rounded-xl grayscale opacity-90 hover:opacity-100 transition-opacity duration-300" />
          <div class="absolute inset-0 -z-10 blur-3xl opacity-20 rounded-full scale-75 translate-x-4 translate-y-4"
               style="background:var(--color-accent)"></div>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     SERVICES
═══════════════════════════════════════ -->
<section id="services" class="section-padding bg-secondary relative">
  <div class="absolute top-0 left-0 right-0 divider"></div>

  <div class="container-main">
    <div class="mb-16">
      <span class="label block mb-4">Services</span>
      <h2 class="heading-lg max-w-2xl">
        Three ways to work together, depending on your emergency.
      </h2>
    </div>

    <div class="grid md:grid-cols-12 gap-6">

      <!-- Service 01 -->
      <div class="md:col-span-12 lg:col-span-6 card p-8 relative group">
        <div class="absolute top-6 right-6"><span class="label">01</span></div>
        <div class="mb-6">
          <span class="offer-badge">Daily rate</span>
        </div>
        <h3 class="heading-md mb-4">Crisis Remediation</h3>
        <p class="text-body mb-6">
          For Senior Leaders whose project or team is repeatedly failing over critical deliveries or to achieve critical SLAs.
          <br/>
          I step in within hours, own P1s and escalations, regain stakeholders' trust and re-establish a streamlined Core able to cope again.
        </p>
        <div class="flex items-center gap-2 text-muted">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-sm">&lt; 8 weeks · incl. 24/7 OnCall readiness</span>
        </div>
      </div>

      <!-- Service 02 -->
      <div class="md:col-span-12 lg:col-span-6 card p-8 relative group">
        <div class="absolute top-6 right-6"><span class="label">02</span></div>
        <div class="mb-6">
          <span class="offer-badge">Monthly retainer</span>
        </div>
        <h3 class="heading-md mb-4">Interim Management</h3>
        <p class="text-body mb-6">
          For Senior Leaders seeking to close leadership gaps during unplanned management transitions or radical restructurings.
          <br/>
          I take control within a week, make tactical calls, sustain performance, and hand over cleanly when the time comes.
        </p>
        <div class="flex items-center gap-2 text-muted">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-sm">Scope-dependent · hand-over included</span>
        </div>
      </div>

      <!-- Service 03 – full-width feature card -->
      <div class="md:col-span-12 card p-8 relative group"
           style="background:linear-gradient(135deg,var(--color-bg-primary) 0%,var(--color-bg-secondary) 100%)">
        <div class="absolute top-6 right-6"><span class="label">03</span></div>
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <div class="mb-6">
              <span class="offer-badge">Outcome-based</span>
            </div>
            <h3 class="heading-md mb-4">Project (Re-)Initiation</h3>
            <p class="text-body">
              For Senior Leaders who need to drive a critical ramp-up, turnaround, or major delivery
              — without the overhead of a full PM. I create initial structures and
              coach one of your talents to lead the project to success. </br></br>
            </p>
          </div>
          <div class="flex flex-col justify-center space-y-4">
            {[
              "Reconquest of lost Stakeholders",
              "Project (re-)scoping and structuring",
              "Scope broken down in Epics and Stories",
              "2 Sprints completed and next 2 PIs planned",
              "team-inside Talent coached and ready to take over",
            ].map(item => (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-body">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-2 text-muted">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-sm">6 - 12 weeks · incl. first 2 Sprints</span>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     WORK / EXPERIENCE
═══════════════════════════════════════ -->
<section id="work" class="section-padding bg-primary relative">
  <div class="absolute top-0 left-0 right-0 divider"></div>

  <div class="container-main">
    <div class="grid md:grid-cols-2 gap-8 mb-16">
      <div>
        <span class="label block mb-4">Experience</span>
        <h2 class="heading-lg">
          High-stakes mandates in regulated industries.
        </h2>
      </div>
      <div class="flex items-end">
        <p class="text-body">
          Every role below involved direct accountability for staff engagement, service quality, project outcomes and multi-million budgets — in mission-critical environments where failure wasn't an option.
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

      <!-- Work  -->
      <div class="card p-8 relative overflow-hidden group">
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="heading-md">AXA Switzerland</h3>
            <span class="duration-badge">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              6 years
            </span>
          </div>
          <p class="text-body-sm mb-4 text-muted">2019–2025 · VP, Head of Digital Advisory & Omni-Channel</p>
          <h4 class="text-body mb-4" style="color:var(--color-text-primary)">Led 4 agile product teams end-to-end</h4>
          <p class="text-body-sm mb-6">
            Over 40 FTEs across Switzerland and Serbia, CHF 3.5M annual budget. Owner of FINMA-critical CRM sales platform (99.9% availability). Sponsored SAP S/4 HANA migration.
          </p>
          <div class="flex flex-wrap gap-2">
            {["CRM", "SAP S/4 HANA", "FINMA", "Agile", "B2E"].map(t => (
              <span class="text-xs px-3 py-1 rounded-full border text-muted" style="border-color:var(--color-border)">{t}</span>
            ))}
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(212,165,116,0.05)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>

      <!-- Role 02 -->
      <div class="card p-8 relative overflow-hidden group">
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="heading-md">AXA Switzerland</h3>
            <span class="duration-badge">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              6 months
            </span>
          </div>
          <p class="text-body-sm mb-4 text-muted">2024 · a.i. Head of Sales Region (Leiter Aussendienst SRO)</p>
          <h4 class="text-body mb-4" style="color:var(--color-text-primary)">Full sales region leadership ad interim</h4>
          <p class="text-body-sm mb-6">
            Accountable for 9 General Agents, 52 points of sale and 350+ advisors across all branches — total GWP over CHF 800M in P&C. Performance management, coaching, and FINMA compliance.
          </p>
          <div class="flex flex-wrap gap-2">
            {["P&C Insurance", "FINMA", "Interim Leadership", "350+ FTEs"].map(t => (
              <span class="text-xs px-3 py-1 rounded-full border text-muted" style="border-color:var(--color-border)">{t}</span>
            ))}
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(212,165,116,0.05)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>

      <!-- Role 03 -->
      <div class="card p-8 relative overflow-hidden group">
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="heading-md">Swiss Re</h3>
            <span class="duration-badge">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              2 years
            </span>
          </div>
          <p class="text-body-sm mb-4 text-muted">2017–2019 · Director, Global Head L&H Data Propositions</p>
          <h4 class="text-body mb-4" style="color:var(--color-text-primary)">Global AI/data programme across 4 continents</h4>
          <p class="text-body-sm mb-6">
            5 direct reports in UK and India, dotted-line over 10+ FTEs across US, Asia, and India. Responsible for all AI use cases and implementations in Life & Health Reinsurance.
          </p>
          <div class="flex flex-wrap gap-2">
            {["AI/Data", "Reinsurance", "L&H", "Global", "5 direct reports"].map(t => (
              <span class="text-xs px-3 py-1 rounded-full border text-muted" style="border-color:var(--color-border)">{t}</span>
            ))}
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(212,165,116,0.05)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>

      <!-- Role 04 -->
      <div class="card p-8 relative overflow-hidden group">
        <div class="relative z-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="heading-md">AXA Switzerland</h3>
            <span class="duration-badge">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              3 years
            </span>
          </div>
          <p class="text-body-sm mb-4 text-muted">2014–2017 · VP, Head of Business Development Big Data</p>
          <h4 class="text-body mb-4" style="color:var(--color-text-primary)">Deputy CDO — data & AI across the value chain</h4>
          <p class="text-body-sm mb-6">
            Identified and implemented data/AI use cases from underwriting to claims. Led Oracle → SAP-BW enterprise data warehouse migration for Marketing and Distribution.
          </p>
          <div class="flex flex-wrap gap-2">
            {["Big Data", "AI", "CDO Office", "SAP-BW", "Oracle"].map(t => (
              <span class="text-xs px-3 py-1 rounded-full border text-muted" style="border-color:var(--color-border)">{t}</span>
            ))}
          </div>
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(212,165,116,0.05)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>

    </div>

    <!-- Link to references -->
    <div class="mt-10 card p-6 flex flex-col sm:flex-row sm:items-center gap-4"
         style="background:linear-gradient(135deg,var(--color-bg-primary) 0%,var(--color-bg-secondary) 100%)">
    <div class="flex flex-wrap gap-4 animate-fade-in-up delay-600">
        <a href="https://quentinmaestripieri.com/references" class="btn-primary">
        Discover more about the teams I've helped
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
        </a>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     ABOUT
═══════════════════════════════════════ -->
<section id="about" class="section-padding bg-secondary relative">
  <div class="absolute top-0 left-0 right-0 divider"></div>

  <div class="container-main">
    <div class="mb-16">
      <span class="label block mb-4">About</span>
      <h2 class="heading-lg max-w-3xl">
        I don't own your team. I own your underlying problem until it's solved.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">

      {[
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
          title: "Proven in crisis",
          body: "Specialized in high-octane interventions. I've stabilised failing teams and projects in high-availability environments where the cost of the next failure is existential."
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
          title: "Board-level fluent",
          body: "VP and Director at AXA and Swiss Re. I speak the language of C-Suite stakeholders and translate it for your teams — without losing anything in translation."
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>`,
          title: "Tech-literate Leader",
          body: "I code in 5 languages and have led teams from Mobile Apps and ERPs all the way down deep Infra. No matter where they're at, I can cut clean through their complexity"
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
          title: "Clean succession",
          body: "I drop in, stabilise, and leave a team that runs without me. My mandates end with streamlined processes, re-engaged stakeholders, and a clear hand-over to the next leader."
        },
      ].map(card => (
        <div class="group">
          <div class="mb-4 w-12 h-12 rounded-lg bg-accent-subtle flex items-center justify-center">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={card.icon} />
          </div>
          <h3 class="heading-md mb-3">{card.title}</h3>
          <p class="text-body-sm">{card.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     CONTACT
═══════════════════════════════════════ -->
<section id="contact" class="section-padding bg-primary relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 divider"></div>
  <div class="absolute bottom-0 right-0 w-[600px] h-[600px] pointer-events-none"
       style="background:radial-gradient(circle,rgba(212,165,116,0.06) 0%,transparent 70%)"></div>

  <div class="container-main relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <div>
        <span class="label block mb-4">Contact</span>
        <h2 class="heading-lg mb-6">
          Let's talk about your situation.
        </h2>
        <p class="text-body max-w-md mb-8">
          Whether you're facing a leadership gap, a project running sideways, or a team stuck in endless loops — let's start with a conversation. No obligation, no pitch deck.
        </p>

        <a href="mailto:quentin.maestripieri@gmail.com" class="btn-primary mb-8 inline-flex">
          Get in touch
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <div class="flex flex-col gap-4 mt-8">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:quentin.maestripieri@gmail.com" class="link-hover text-base">quentin.maestripieri@gmail.com</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+41797993825" class="link-hover text-base">+41 79 799 38 25</a>
